{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Static portfolio site served with a tiny Node server.",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node server.js",
    "build": "node node_modules/tailwindcss/lib/cli.js -i ./public/css/tailwind-source.css -o ./public/css/tailwind.css",
    "watch": "node node_modules/tailwindcss/lib/cli.js -i ./public/css/tailwind-source.css -o ./public/css/tailwind.css --watch"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}

