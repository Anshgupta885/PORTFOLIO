{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Static portfolio site served with a tiny Node server.",
  "scripts": {
    "dev": "node server.js",
    "build:css": "tailwindcss -i ./public/css/tailwind-source.css -o ./public/css/tailwind.css",
    "build": "npm run build:css",
    "watch": "tailwindcss -i ./public/css/tailwind-source.css -o ./public/css/tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
